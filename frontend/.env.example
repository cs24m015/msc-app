# Timezone for date/time display (default: UTC)
# Examples: Europe/Vienna, America/New_York, Asia/Tokyo
VITE_TIMEZONE=UTC

# Domain for share feature URLs (optional)
VITE_DOMAIN=hecate.pw

# Enable/disable AI analysis features (default: true)
# Set to "false" to hide AI-Analyse page and AI tabs in vulnerability details
VITE_AI_FEATURES_ENABLED=true