# Backend configuration template for Hecate

ENVIRONMENT=development
API_PREFIX=/api/v1

# MongoDB connection
MONGO_URL=mongodb://mongo:27017
MONGO_DB=hecate
MONGO_VULNERABILITIES_COLLECTION=vulnerabilities
MONGO_CPE_COLLECTION=cpe_catalog
MONGO_INGESTION_STATE_COLLECTION=ingestion_state
MONGO_INGESTION_LOG_COLLECTION=ingestion_logs

# OpenSearch connection
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=hecate-vulnerabilities

# AI provider
OPENAI_API_KEY=

# External data sources
EUVD_BASE_URL=https://euvdservices.enisa.europa.eu/api
EUVD_TIMEOUT_SECONDS=30
EUVD_PAGE_SIZE=250
EUVD_RATE_LIMIT_SECONDS=1.0
EUVD_MAX_RECORDS_PER_RUN=2000
VULNERABILITY_INITIAL_BACKFILL_SINCE=
NVD_BASE_URL=https://services.nvd.nist.gov/rest/json
NVD_API_KEY=f85e294e-55d7-4c28-af89-b9bf1bd74f7e
NVD_RATE_LIMIT_SECONDS=0.6
NVD_PAGE_SIZE=2000
CPE_BASE_URL=https://services.nvd.nist.gov/rest/json/cpes/2.0
CPE_MAX_RECORDS_PER_RUN=20000
INGESTION_USER_AGENT=hecate-ingestion/0.1
INGESTION_RUNNING_TIMEOUT_MINUTES=0
INGESTION_BOOTSTRAP_ON_STARTUP=true

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_EUVD_INTERVAL_MINUTES=10
SCHEDULER_CPE_INTERVAL_HOURS=24
SCHEDULER_NVD_INTERVAL_HOURS=1
